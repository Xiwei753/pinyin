<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F0F0"
    android:paddingBottom="8dp">

    <!-- Candidate Bar -->
    <LinearLayout
        android:id="@+id/candidate_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/buffer_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:maxWidth="100dp"
            android:ellipsize="start"
            android:singleLine="true"
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="center_vertical"
            android:paddingEnd="8dp"
            android:visibility="visible" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">
            <LinearLayout
                android:id="@+id/candidate_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Chinese/English T9 Panel -->
    <LinearLayout
        android:id="@+id/panel_t9"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp"
        android:visibility="visible">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_1" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="1" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_2" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="2 ABC" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_3" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="3 DEF" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_4" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="4 GHI" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_5" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="5 JKL" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_6" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="6 MNO" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_7" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="7 PQRS" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_8" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="8 TUV" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_9" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg" android:text="9 WXYZ" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 4: function keys -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_toggle_symbol" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="符" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_0" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="0 空格" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/key_del" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="删除" android:gravity="center"
                    android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true"
                    android:longClickable="true" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 5: mode/action keys -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="0dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/key_toggle_english" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="中" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/key_toggle_number" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="123" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/key_hide" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="隐藏" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/key_enter" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="↵" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Symbol Panel -->
    <LinearLayout
        android:id="@+id/panel_symbol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp"
        android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_1" android:background="@drawable/key_bg" android:text="，" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_2" android:background="@drawable/key_bg" android:text="。" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_3" android:background="@drawable/key_bg" android:text="？" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_4" android:background="@drawable/key_bg" android:text="！" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_5" android:background="@drawable/key_bg" android:text="：" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_6" android:background="@drawable/key_bg" android:text="；" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_7" android:background="@drawable/key_bg" android:text="、" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_8" android:background="@drawable/key_bg" android:text="“" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_9" android:background="@drawable/key_bg" android:text="”" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_10" android:background="@drawable/key_bg" android:text="‘" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_11" android:background="@drawable/key_bg" android:text="’" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_12" android:background="@drawable/key_bg" android:text="（" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_13" android:background="@drawable/key_bg" android:text="）" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_14" android:background="@drawable/key_bg" android:text="《" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_15" android:background="@drawable/key_bg" android:text="》" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_16" android:background="@drawable/key_bg" android:text="—" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_17" android:background="@drawable/key_bg" android:text="…" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_18" android:background="@drawable/key_bg" android:text="@" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_19" android:background="@drawable/key_bg" android:text="#" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_20" android:background="@drawable/key_bg" android:text="￥" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_21" android:background="@drawable/key_bg" android:text="%" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_22" android:background="@drawable/key_bg" android:text="&amp;" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_23" android:background="@drawable/key_bg" android:text="*" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_24" android:background="@drawable/key_bg" android:text="+" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="4dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_25" android:background="@drawable/key_bg" android:text="-" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_26" android:background="@drawable/key_bg" android:text="=" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_27" android:background="@drawable/key_bg" android:text="/" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_28" android:background="@drawable/key_bg" android:text="\" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_29" android:background="@drawable/key_bg" android:text="&lt;" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:padding="3dp">
                <TextView android:id="@+id/sym_30" android:background="@drawable/key_bg" android:text=">" android:gravity="center" android:textSize="18sp" android:textColor="#333333" android:clickable="true" android:focusable="true" android:layout_width="match_parent" android:layout_height="match_parent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="0dp">
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/sym_back" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="中文" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/sym_number" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="123" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
                <TextView android:id="@+id/sym_del" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/key_bg_special" android:text="删除" android:gravity="center"
                    android:textSize="16sp" android:textColor="#333333" android:clickable="true" android:focusable="true" />
            </FrameLayout>
            <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp" android:padding="3dp">
